dol_finance_jobs <- map_dfr(dol_file_list, get_finance_jobs)
## H1B DOL 2016-24
dol_folder_path <- "dol_h1b"
dol_file_list <- list.files("dol_h1b", pattern = "\\.xlsx$", full.names = TRUE)
finance_keywords <- c(
"financ", "investment", "account", "accounting", "business", "audit",
"tax", "actuary", "treasury", "risk", "compliance", "market", "quantitative"
)
pattern <- paste(finance_keywords, collapse = "|")
get_finance_jobs <- function(file) {
df <- read_excel(file) |> clean_names()
if (all(c("job_title", "worksite_state", "wage_rate_of_pay_from") %in% names(df))) {
df %>%
filter(grepl(pattern, job_title, ignore.case = TRUE)) %>%
select(job_title, worksite_state, wage = wage_rate_of_pay_from) %>%
mutate(source_file = basename(file))
} else {
NULL
}
}
dol_finance_jobs <- map_dfr(dol_file_list, get_finance_jobs)
head(dol_finance_jobs)
print(dol_finance_jobs, n = Inf)
