library(dplyr)
library(stringr)
library(text2vec)
library(cluster)
library(factoextra)
library(ggplot2)
library(tibble)
library(tidyr)
library(irlba)
finance_keywords <- c(
"financ", "invest", "account", "audit", "tax",
"actuary", "treasury", "risk", "compliance", "quantitative",
"portfolio", "equity", "asset", "securities", "hedge",
"valuation", "credit", "bank", "underwriter"
)
pattern <- paste(finance_keywords, collapse = "|")
dol_2016_tc <- read_excel("dol_h1b/H-1B_Disclosure_Data_FY16.xlsx") %>%
clean_names() %>%
filter(!is.na(job_title)) %>%
filter(grepl(pattern, job_title, ignore.case = TRUE)) %>%
select(job_title)
titles <- dol_2016_tc$job_title |> unique() |> tolower()
titles_clean <- titles |>
str_replace_all("[^a-z ]", " ") |>
str_squish()
it <- itoken(titles_clean, progressbar = FALSE)
vocab <- create_vocabulary(it)
vectorizer <- vocab_vectorizer(vocab)
dtm <- create_dtm(it, vectorizer)
tfidf <- TfIdf$new()
dtm_tfidf <- fit_transform(dtm, tfidf)
dtm_svd <- irlba(dtm_tfidf, nv = 50)$u
set.seed(123)
k <- 10
km <- kmeans(dtm_svd, centers = k)
# Combine titles with clusters
clustered_titles <- data.frame(
title = titles_clean,
cluster = km$cluster
)
clustered_titles %>%
group_by(cluster) %>%
summarise(sample_titles = paste(head(title, 5), collapse = "; "), .groups = "drop") %>%
print(n = Inf)
df_2016_finance <- dol_2016_tc %>%
filter(grepl(pattern, job_title, ignore.case = TRUE)) %>%
mutate(job_title_clean = tolower(job_title)) %>%
left_join(clustered_titles, by = c("job_title_clean" = "title")) %>%
mutate(annual_wage = as.numeric(wage_rate_of_pay_from) * wage_conversion[as.character(wage_unit_of_pay)])
df_2016_finance %>%
group_by(cluster) %>%
summarise(mean_wage = mean(annual_wage, na.rm = TRUE), n = n())
df_2016_finance <- dol_2016_tc %>%
filter(grepl(pattern, job_title, ignore.case = TRUE)) %>%
mutate(job_title_clean = tolower(job_title)) %>%
left_join(clustered_titles, by = c("job_title_clean" = "title")) %>%
mutate(annual_wage = as.numeric(wage_rate_of_pay_from) * wage_conversion[as.character(wage_unit_of_pay)])
df_2016_finance %>%
group_by(cluster) %>%
summarise(mean_wage = mean(annual_wage, na.rm = TRUE), n = n())
