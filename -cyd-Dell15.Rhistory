library(dplyr)
library(stringr)
library(text2vec)
library(cluster)
library(factoextra)
library(ggplot2)
library(tibble)
library(tidyr)
library(irlba)
dol_2016_tc <- read_excel("dol_h1b/H-1B_Disclosure_Data_FY16.xlsx") %>%
clean_names() %>%
filter(!is.na(job_title)) %>%
select(job_title)
# Extract unique, cleaned titles
titles <- dol_2016_tc$job_title |> unique() |> tolower()
titles_clean <- titles |>
str_replace_all("[^a-z ]", " ") |>
str_squish()
# TF-IDF + SVD + K-means clustering
it <- itoken(titles_clean, progressbar = FALSE)
vocab <- create_vocabulary(it)
vectorizer <- vocab_vectorizer(vocab)
dtm <- create_dtm(it, vectorizer)
tfidf <- TfIdf$new()
dtm_tfidf <- fit_transform(dtm, tfidf)
dtm_svd <- irlba(dtm_tfidf, nv = 50)$u
set.seed(123)
k <- 10
km <- kmeans(dtm_svd, centers = k)
# Combine titles with clusters
clustered_titles <- data.frame(
title = titles_clean,
cluster = km$cluster
)
# View clustered title samples
clustered_titles %>%
group_by(cluster) %>%
summarise(sample_titles = paste(head(title, 5), collapse = "; "), .groups = "drop") %>%
print(n = Inf)
rm(list=ls())                          # Clear environment
oldpar <- par()                        # save default graphical parameters
if (!is.null(dev.list()["RStudioGD"])) # Clear plot window
dev.off(dev.list()["RStudioGD"])
